# Supabase PostgreSQL Connection String (Transaction mode or Direct)
# Example: postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Secret key to validate webhooks from Supabase
# Same as configured in Supabase Dashboard
WEBHOOK_SECRET=your_super_secret_key

# Port to run the server
PORT=8080
